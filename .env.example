# Copy this to .env and fill in your keys. .env is gitignored.
# scripts/dev.sh loads it automatically.

# Required for live answers (console.anthropic.com).
ANTHROPIC_API_KEY=sk-ant-...

# Optional, for re-fetching FEC data (free key at https://api.data.gov/signup/).
# Falls back to the throttled DEMO_KEY if unset.
FEC_API_KEY=your-api-data-gov-key
