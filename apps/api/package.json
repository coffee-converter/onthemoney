{
  "name": "otm-api",
  "version": "0.1.0",
  "private": true,
  "description": "On The Money BFF: typed contracts and stream relay in front of the agent service.",
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/scoreboard && cp src/scoreboard/scoreboard.json dist/scoreboard/scoreboard.json",
    "start": "node dist/main.js",
    "test": "jest"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.2"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {"^.+\\.ts$": "ts-jest"},
    "testEnvironment": "node"
  }
}
